<style>
  /* ─────────────────────────────────────────
     SHARED MARKETING STYLES
  ───────────────────────────────────────── */
  body { background: #f5f6f8; }

  .mkt-section {
    padding: 5rem 0;
  }
  .mkt-section-white {
    background: #fff;
  }

  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #CD0000;
    margin-bottom: 1rem;
  }
  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: #1a1a1a;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .section-title-red {
    color: #CD0000;
  }
  .section-sub {
    font-size: 1.1rem;
    color: #6b7280;
    line-height: 1.7;
    max-width: 680px;
    margin: 0 auto;
  }

  /* feature cards */
  .feat-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 2rem;
    height: 100%;
  }
  .feat-card-icon {
    font-size: 1.8rem;
    color: #CD0000;
    margin-bottom: 1rem;
  }
  .feat-card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 0.5rem;
  }
  .feat-card-body {
    font-size: 0.95rem;
    color: #6b7280;
    line-height: 1.65;
    margin: 0;
  }

  /* check-item cards */
  .check-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1.1rem 1.4rem;
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
  }
  .check-card .check-icon {
    color: #CD0000;
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .check-card p {
    margin: 0;
    font-size: 0.97rem;
    color: #374151;
    line-height: 1.55;
  }

  /* inline check list (no card border) */
  .check-list-item {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    margin-bottom: 1rem;
  }
  .check-list-item .check-icon { color: #CD0000; font-size: 1.1rem; flex-shrink: 0; margin-top: 2px; }
  .check-list-item p { margin: 0; font-size: 1rem; color: #374151; line-height: 1.55; }

  /* step numbers */
  .step-num {
    font-size: 5rem;
    font-weight: 900;
    color: #f0c0c0;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  /* strikethrough rows */
  .strikethrough-row {
    font-size: 1.05rem;
    color: #b0b0b0;
    text-decoration: line-through;
    border-bottom: 1px solid #e5e7eb;
    padding: 0.9rem 0;
    display: block;
  }

  /* ── Nav ── */
  .nav-marketing {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    padding: 0.85rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-marketing .brand-text {
    font-size: 1.1rem;
    font-weight: 900;
    color: #1a1a1a;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .nav-marketing .nav-lnk {
    color: #555;
    font-weight: 500;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-marketing .nav-lnk:hover { color: #1a1a1a; }
  .nav-marketing .nav-lnk.is-active { color: #CD0000; }

  /* ── Hero ── */
  .hero-section {
    background: #f5f6f8;
    min-height: calc(100vh - 64px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 0 3rem;
  }
  .hero-line-1 {
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    font-weight: 900;
    color: #1a1a1a;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0;
  }
  .hero-line-2 {
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    font-weight: 900;
    color: #888;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0;
  }
  .rotating-word-wrap {
    display: inline-block;
    padding-bottom: 6px;
    border-bottom: 4px solid #CD0000;
    transition: border-color 0.3s;
    line-height: 1.1;
  }
  #rotating-word {
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    font-weight: 900;
    color: #CD0000;
    letter-spacing: -0.03em;
    display: block;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  #rotating-word.fading {
    opacity: 0;
    transform: translateY(-6px);
  }
  .audience-pill {
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.4rem 1.1rem;
    border-radius: 999px;
    border: none;
    background: transparent;
    color: #666;
    cursor: pointer;
    transition: background 0.25s, color 0.25s;
  }
  .audience-pill.active { background: #1a1a1a; color: #fff; }
  .audience-pill:hover:not(.active) { color: #1a1a1a; }

  /* ── Browser mockup ── */
  .browser-mockup {
    width: 100%;
    max-width: 460px;
    border-radius: 14px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.13);
    overflow: hidden;
  }
  .browser-chrome {
    background: #e2e2e2;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .browser-dots { display: flex; gap: 6px; }
  .browser-dot { width: 12px; height: 12px; border-radius: 50%; }
  .browser-url {
    flex: 1;
    background: #fff;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 0.78rem;
    color: #888;
    text-align: center;
  }
  .browser-body-wrap {
    background: #fff;
    padding: 2rem 2rem 2.5rem;
    min-height: 320px;
    perspective: 800px;
  }
  #browser-card { transform-style: preserve-3d; will-change: transform; }
  .feature-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.8rem;
    border-radius: 6px;
    border: 2px solid;
    margin-bottom: 1.4rem;
  }
  .browser-headline {
    font-size: 1.55rem;
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1.25;
    margin-bottom: 0.65rem;
  }
  .browser-body-text {
    font-size: 0.95rem;
    color: #6b7280;
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }
  .see-how-btn {
    font-size: 1rem;
    font-weight: 700;
    padding: 0.7rem 1.8rem;
    border-radius: 10px;
    border: none;
    color: #fff;
    cursor: pointer;
  }
  .scroll-indicator { text-align: center; margin-top: 3rem; color: #aaa; font-size: 0.85rem; }

  /* ── Contact form ── */
  .contact-form-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 2rem 2.25rem;
  }
  .contact-form-card label {
    font-size: 0.9rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 0.35rem;
    display: block;
  }
  .contact-form-card input,
  .contact-form-card textarea {
    width: 100%;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    color: #374151;
    background: #fafafa;
    margin-bottom: 1.25rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .contact-form-card input:focus,
  .contact-form-card textarea:focus { border-color: #CD0000; }
  .contact-form-card textarea { min-height: 110px; resize: vertical; }

  /* ── Footer ── */
  .mkt-footer {
    background: #fff;
    border-top: 1px solid #e5e7eb;
    padding: 3rem 0 1.5rem;
  }
  .footer-logo-text {
    font-size: 1.6rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a1a1a;
  }
  .footer-logo-text span { color: #CD0000; }
  .footer-desc { font-size: 0.95rem; color: #6b7280; max-width: 360px; line-height: 1.65; }
  .footer-links a { color: #CD0000; text-decoration: none; font-size: 0.95rem; font-weight: 500; display: block; margin-bottom: 0.6rem; }
  .footer-links a:hover { text-decoration: underline; }
  .footer-copy { font-size: 0.85rem; color: #9ca3af; text-align: center; margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid #e5e7eb; }

  @media (max-width: 991px) {
    .hero-right { margin-top: 2.5rem; }
    .step-num { font-size: 3.5rem; }
  }
</style>

<!-- ══════════════════════════════════════
     NAV
══════════════════════════════════════ -->
<nav class="nav-marketing">
  <div class="container d-flex align-items-center justify-content-between">
    <a href="/" class="text-decoration-none d-flex align-items-center gap-2">
      <%= image_tag "version-lab-icon.png", height: 30, alt: "Version Lab" %>
      <span class="brand-text">Version Lab</span>
    </a>
    <div class="d-flex align-items-center gap-4">
      <a href="/" class="nav-lnk is-active">Home</a>
      <a href="/pricing" class="nav-lnk">Pricing</a>
      <a href="/contact" class="nav-lnk">Contact</a>
      <% if user_signed_in? %>
        <%= link_to "Go to App", "/app", class: "nav-lnk" %>
        <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-sm btn-outline-secondary ms-2" %>
      <% else %>
        <%= link_to "Login", new_user_session_path, class: "nav-lnk" %>
        <%= link_to "Start a Free Trial", onboarding_path, class: "btn btn-danger fw-semibold px-4 ms-2" %>
      <% end %>
    </div>
  </div>
</nav>

<!-- ══════════════════════════════════════
     SECTION 1 — HERO
══════════════════════════════════════ -->
<section class="hero-section">
  <div class="container">
    <div class="row align-items-center g-5">

      <!-- Left -->
      <div class="col-lg-6">
        <div class="mb-4">
          <p class="hero-line-1">Speed + Control.</p>
