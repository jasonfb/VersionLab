<script>
(function () {
  const AUDIENCES = [
    {
      word: 'Agencies', wordColor: '#CD0000', lineColor: '#CD0000',
      badge: 'GOVERNED', badgeColor: '#CD0000',
      headline: 'Segment Without Sprawl.',
      body: 'One master email. Every lifecycle stage. No template duplication.',
      btnColor: '#CD0000'
    },
    {
      word: 'In-House', wordColor: '#1a1a1a', lineColor: '#1a1a1a',
      badge: 'BRAND SAFE', badgeColor: '#1a1a1a',
      headline: 'Your Brand. Locked Down.',
      body: 'Fonts, colors, and tone rules enforced at generation time. Zero cleanup.',
      btnColor: '#555'
    },
    {
      word: 'CRM Teams', wordColor: '#CD0000', lineColor: '#CD0000',
      badge: 'PRODUCTION-READY', badgeColor: '#CD0000',
      headline: '47 Variants. One Source File.',
      body: 'Deploy governed creative across every client segment without rebuilding a single layout.',
      btnColor: '#CD0000'
    }
  ];

  let current = 0;
  let timer   = null;

  const wordEl  = document.getElementById('rotating-word');
  const wrapEl  = document.getElementById('rotating-word-wrap');
  const cardEl  = document.getElementById('browser-card');
  const badgeEl = document.getElementById('b-badge');
  const headEl  = document.getElementById('b-headline');
  const bodyEl  = document.getElementById('b-body');
  const btnEl   = document.getElementById('b-btn');
  const pills   = document.querySelectorAll('.audience-pill');

  function goTo(index) {
    if (index === current) return;
    const a = AUDIENCES[index];

    wordEl.classList.add('fading');
    cardEl.style.transition = 'transform 0.2s ease-in';
    cardEl.style.transform  = 'rotateY(-90deg)';

    setTimeout(function () {
      wordEl.textContent       = a.word;
      wordEl.style.color       = a.wordColor;
      wrapEl.style.borderColor = a.lineColor;
      wordEl.classList.remove('fading');

      badgeEl.textContent         = a.badge;
      badgeEl.style.color         = a.badgeColor;
      badgeEl.style.borderColor   = a.badgeColor;
      headEl.textContent          = a.headline;
      bodyEl.textContent          = a.body;
      btnEl.style.backgroundColor = a.btnColor;

      cardEl.style.transition = 'transform 0.2s ease-out';
      cardEl.style.transform  = 'rotateY(0deg)';
    }, 210);

    pills.forEach(function (p, i) { p.classList.toggle('active', i === index); });
    current = index;
  }

  function advance() { goTo((current + 1) % AUDIENCES.length); }
  function resetTimer() { clearInterval(timer); timer = setInterval(advance, 4000); }

  pills.forEach(function (p) {
    p.addEventListener('click', function () {
      goTo(parseInt(p.dataset.index, 10));
      resetTimer();
    });
  });

  resetTimer();
}());
</script>
