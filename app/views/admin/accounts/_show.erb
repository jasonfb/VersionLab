<div class='hg-col col-sm-2 account--name'> <%= account.name %>
</div>
<div class='hg-col col-sm-1 account--is_agency'> <% if account.is_agency.nil? %>
        <span class=''>MISSING</span>
    <% elsif account.is_agency %>
      YES
    <% else %>
      NO
    <% end %>
</div>
<div class='hg-col col-sm-2 account--subscription_status'>
  <% sub = account.active_subscription %>
  <% if sub&.demo? %>
    <span class="badge bg-warning text-dark">Demo</span>
    <% if account.account_locked_out? %>
      <span class="badge bg-danger">Locked</span>
    <% end %>
  <% elsif sub&.free_trial? %>
    <span class="badge bg-info">Free Trial</span>
    <% if account.account_locked_out? %>
      <span class="badge bg-danger">Locked</span>
    <% end %>
  <% elsif sub %>
    <span class="badge bg-success"><%= sub.subscription_tier.name %></span>
  <% else %>
    <span class="badge bg-secondary">None</span>
  <% end %>
  <% if sub&.trial_or_demo? %>
    <br><small class="text-muted"><%= sub.current_cycle_vl_tokens_used %>/<%= sub.effective_monthly_token_allotment %> credits</small>
  <% end %>
</div>
<div class='hg-col col-sm-2 account--customer_chooses_ai'>
  <%= account.customer_chooses_ai? ? "Yes" : "No" %>
</div>
<div class='hg-col col-sm-2 account--ai_config'>
  <% unless account.customer_chooses_ai? %>
    <small><%= account.ai_service&.name %> / <%= account.ai_model&.name %></small>
  <% end %>
</div>


<div class=" scaffold-line-buttons col-md-3" >

    <%= form_with url: admin_account_path(account), html: {data: {'turbo-confirm': "Are you sure you want to delete #{ account.name }?" }, style: "display: inline-block;"}, method: :delete do |f| %>
      <%= f.submit "Delete".html_safe,  class: "delete-account-button btn btn-primary btn-sm", disabled: (account.respond_to?(:delete_able?) && ! account.delete_able? ) %>
    <% end %>


  <%= link_to "Edit ".html_safe, edit_admin_account_path(account) + (params[:page] ? "?page=#{params[:page]}" : ""), 'data-turbo' => 'false', disable_with: "Loading...", class: "edit-account-button btn btn-primary btn-sm" %>

  <% if account.active_subscription&.demo? %>
    <%= button_to "Convert to Free Trial", convert_to_free_trial_admin_account_path(account), method: :post, data: { turbo_confirm: "Convert #{account.name} to a 7-day Free Trial? This will send them a welcome email." }, class: "btn btn-success btn-sm" %>
  <% end %>

</div>
