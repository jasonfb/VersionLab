<div class="container">
  <div class="row">
    <div class="col-md-12">
      <%= render partial: "admin/nav", locals: {nav: "accounts"} %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 offset-md-3">
      <h3>Quick Onboard &mdash; Demo Account</h3>
      <p class="text-muted">Creates a new company with a 1-day demo (250 VL credits). No emails are sent during demo mode.</p>

      <%= form_with url: create_quick_onboard_admin_accounts_path, method: :post, local: true do |f| %>
        <div class="mb-3">
          <%= f.label :first_name, "First Name", class: "form-label" %>
          <%= f.text_field :first_name, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :last_name, "Last Name", class: "form-label" %>
          <%= f.text_field :last_name, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :email, "Email", class: "form-label" %>
          <%= f.email_field :email, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :company_name, "Company Name", class: "form-label" %>
          <%= f.text_field :company_name, class: "form-control", required: true %>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit "Create Demo Account", class: "btn btn-primary" %>
          <%= link_to "Cancel", admin_accounts_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
