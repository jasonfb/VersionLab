<%= turbo_stream.replace "admin__#{dom_id(@ad_platform_size)}" do %>
  <%= render partial: 'line', locals: {ad_platform_size: @ad_platform_size,  ad_platform: @ad_platform }   %>
<% end %>
<!-- parental updated -->
<%= turbo_stream.replace "__admin#{dom_id(@ad_platform)}" do %>
    <%= render partial: "admin/ad_platforms/line", locals: {ad_platform: @ad_platform} %>
  <% end %>
<!-- flash notices -->
<%= turbo_stream.update "flash_notices" do %>
  <%= render partial: "layouts/flash_notices", locals: {resource: @ad_platform_size} %>
<% end %>
