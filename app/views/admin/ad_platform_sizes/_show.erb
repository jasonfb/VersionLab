<div class='hg-col col-sm-2 ad_platform_size--name'> <%= ad_platform_size.name %>
</div>
<div class='hg-col col-sm-2 ad_platform_size--width'> <%= ad_platform_size.width %>
</div>
<div class='hg-col col-sm-2 ad_platform_size--height'> <%= ad_platform_size.height %>
</div>
<div class='hg-col col-sm-2 ad_platform_size--position'> <%= ad_platform_size.position %>
</div>
<div class='hg-col col-sm-2 ad_platform_size--**shape'> <%= render partial: 'shape', locals: {ad_platform_size: ad_platform_size } %></div>







<div class=" scaffold-line-buttons col-md-2" >
  

  
    <%= form_with url: admin_ad_platform_ad_platform_size_path(ad_platform,ad_platform_size), html: {data: {'turbo-confirm': "Are you sure you want to delete #{ ad_platform_size.name }?" }, style: "display: inline-block;"}, method: :delete do |f| %>
      <%= f.submit "Delete".html_safe,  class: "delete-ad_platform_size-button btn btn-primary btn-sm", disabled: (ad_platform_size.respond_to?(:delete_able?) && ! ad_platform_size.delete_able? ) %>
    <% end %>
  

  
  <%= link_to "Edit ".html_safe, edit_admin_ad_platform_ad_platform_size_path(ad_platform,ad_platform_size) + (params[:page] ? "?page=#{params[:page]}" : ""), disable_with: "Loading...", class: "edit-ad_platform_size-button btn btn-primary btn-sm" %>
  
</div>
