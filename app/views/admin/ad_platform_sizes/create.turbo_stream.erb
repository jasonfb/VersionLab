<% if @ad_platform_size.errors.none? %>
  <%= turbo_stream.replace "admin__ad_platform_sizes-list" + "__ad_platform-#{@ad_platform.id}" do %>
  <%= render partial: "list", locals: {ad_platform_sizes: @ad_platform_sizes,
   ad_platform: @ad_platform,
  nested_for: "ad_platform-#{@ad_platform.id}" 
} %>

<% end %>
  <% end %>
<!-- parental updated -->
<%= turbo_stream.replace "__admin#{dom_id(@ad_platform)}" do %>
    <%= render partial: "admin/ad_platforms/line", locals: {ad_platform: @ad_platform} %>
  <% end %>
<!-- errors -->
  <%= turbo_stream.replace "admin__ad_platform_size-new" do %>
  <% if @ad_platform_size.errors.none? %>
  <%= render partial: "new_button", locals: {
ad_platform: @ad_platform

} %>
  <% else %>
  <%= render partial: "new_form", locals: {ad_platform_size: @ad_platform_size, ad_platform: @ad_platform } %>
  <% end %>
  <% end %>
  <%= turbo_stream.replace "flash_notices" do %>
  <%= render partial: "layouts/flash_notices", locals: {resource: @ad_platform_size} %>
<% end %>
