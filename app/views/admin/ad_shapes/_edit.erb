<%= turbo_frame_tag "admin__#{dom_id(ad_shape)}" do  %>
<div class="cell editable" style="position: relative;">
  <% if ad_shape.errors.any? %>
  <%= render(partial: "admin/errors", locals: {resource: ad_shape }) %>
  <% end %>
  <h2>Editing <%= ad_shape.name %></h2>
  <%= form_with model: ad_shape,
   url: admin_ad_shape_path(ad_shape), html: {'data-turbo': false} do |f| %>
    <%=  render partial: "admin/ad_shapes/form", locals: {
      ad_shape: ad_shape,
      f: f,
      
  } %>
  
  <% end %>
  
</div>
<% end %>
