<%= turbo_stream.replace "admin__#{dom_id(@account_user)}" do %>
  <%= render partial: 'line', locals: {account_user: @account_user,  account: @account }   %>
<% end %>
<!-- parental updated -->
<%= turbo_stream.replace "__admin#{dom_id(@account)}" do %>
    <%= render partial: "admin/accounts/line", locals: {account: @account} %>
  <% end %>
<!-- flash notices -->
<%= turbo_stream.update "flash_notices" do %>
  <%= render partial: "layouts/flash_notices", locals: {resource: @account_user} %>
<% end %>
