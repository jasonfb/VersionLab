<% if @account_user.errors.none? %>
  <%= turbo_stream.replace "admin__account_users-list" + "__account-#{@account.id}" do %>
  <%= render partial: "list", locals: {account_users: @account_users,
   account: @account,
  nested_for: "account-#{@account.id}" 
} %>

<% end %>
  <% end %>
<!-- parental updated -->
<%= turbo_stream.replace "__admin#{dom_id(@account)}" do %>
    <%= render partial: "admin/accounts/line", locals: {account: @account} %>
  <% end %>
<!-- errors -->
  <%= turbo_stream.replace "admin__account_user-new" do %>
  <% if @account_user.errors.none? %>
  <%= render partial: "new_button", locals: {
account: @account

} %>
  <% else %>
  <%= render partial: "new_form", locals: {account_user: @account_user, account: @account } %>
  <% end %>
  <% end %>
  <%= turbo_stream.replace "flash_notices" do %>
  <%= render partial: "layouts/flash_notices", locals: {resource: @account_user} %>
<% end %>
