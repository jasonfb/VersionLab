<div class="row">
  <div class='col-md-2 cell--ad_platform--name' >  
    <div class='<%= "alert alert-danger" if ad_platform.errors.details.keys.include?(:name) %>'  >
        <%= f.text_field :name, value: ad_platform.name, autocomplete: 'off', size: 40, class: 'form-control', type: '' %>
       
      
      <label class='text-muted small form-text' for=''>Name</label>
    </div>
   
  </div>
  <div class='col-md-2 cell--ad_platform--position' >  
    <div class='<%= "alert alert-danger" if ad_platform.errors.details.keys.include?(:position) %>'  >
        <%= f.text_field :position, value: ad_platform.position, autocomplete: 'off', size: 4, class: 'form-control', type: 'number' %>
       
      
      <label class='text-muted small form-text' for=''>Position</label>
    </div>
   
  </div>

  <div class="col-md-2">
    <%= link_to "Cancel", admin_ad_platforms_path + (params[:page] ? "?page=" + params[:page] : ""),  {class: "btn btn-secondary"} %>
    <%= f.submit "Save", class: "btn btn-primary pull-right" %>
  </div>
</div>
