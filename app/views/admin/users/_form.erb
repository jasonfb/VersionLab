<div class="row">
  <div class='col-md-2 cell--user--email' >  
    <div class='<%= "alert alert-danger" if user.errors.details.keys.include?(:email) %>'  >
        <%= f.text_field :email, value: user.email, autocomplete: 'off', size: 40, class: 'form-control', type: '' %>
       
      
      <label class='text-muted small form-text' for=''>Email</label>
    </div>
   
  </div>
  <div class='col-md-2 cell--user--name' >  
    <div class='<%= "alert alert-danger" if user.errors.details.keys.include?(:name) %>'  >
        <%= f.text_field :name, value: user.name, autocomplete: 'off', size: 40, class: 'form-control', type: '' %>
       
      
      <label class='text-muted small form-text' for=''>Name</label>
    </div>
   
  </div>

  <% if current_user.superadmin? %>
  <div class='col-md-3 cell--user--roles'>
    <label class='text-muted small form-text'>Roles</label>
    <div>
      <% Role.all.order(:name).each do |role| %>
        <div class="form-check form-check-inline">
          <%= check_box_tag "user[role_ids][]", role.id,
              user.role_ids.include?(role.id),
              id: "user_role_#{role.id}",
              class: "form-check-input" %>
          <label class="form-check-label" for="user_role_<%= role.id %>"><%= role.label %></label>
        </div>
      <% end %>
      <%= hidden_field_tag "user[role_ids][]", "" %>
    </div>
  </div>
  <% end %>

  <div class="col-md-2">
    <%= link_to "Cancel", admin_users_path + (params[:page] ? "?page=" + params[:page] : ""),  {class: "btn btn-secondary"} %>
    <%= f.submit "Save", class: "btn btn-primary pull-right" %>
  </div>
</div>
