<div class='hg-col col-sm-2 user--email'> <%= user.email %>
</div>
<div class='hg-col col-sm-2 user--name'> <%= user.name %>
</div>







<div class=" scaffold-line-buttons col-md-2" >
  

  
    <%= form_with url: admin_user_path(user), html: {data: {'turbo-confirm': "Are you sure you want to delete #{ user.name }?" }, style: "display: inline-block;"}, method: :delete do |f| %>
      <%= f.submit "Delete".html_safe,  class: "delete-user-button btn btn-primary btn-sm", disabled: (user.respond_to?(:delete_able?) && ! user.delete_able? ) %>
    <% end %>
  

  
  <%= link_to "Edit ".html_safe, edit_admin_user_path(user) + (params[:page] ? "?page=#{params[:page]}" : ""), disable_with: "Loading...", class: "edit-user-button btn btn-primary btn-sm" %>
  
</div>
