<div class='hg-col col-sm-1'><strong><%= ad_shape_layout_rule.role %></strong></div>
<div class='hg-col col-sm-1'><%= ad_shape_layout_rule.drop? ? "YES" : "no" %></div>
<div class='hg-col col-sm-1'><%= ad_shape_layout_rule.drop? ? "—" : ad_shape_layout_rule.anchor_x %></div>
<div class='hg-col col-sm-1'><%= ad_shape_layout_rule.drop? ? "—" : ad_shape_layout_rule.anchor_y %></div>
<div class='hg-col col-sm-1'><%= ad_shape_layout_rule.drop? ? "—" : ad_shape_layout_rule.anchor_w %></div>
<div class='hg-col col-sm-1'><%= ad_shape_layout_rule.drop? ? "—" : ad_shape_layout_rule.anchor_h %></div>
<div class='hg-col col-sm-1'><%= ad_shape_layout_rule.drop? ? "—" : ad_shape_layout_rule.font_scale %></div>
<div class='hg-col col-sm-1'><%= ad_shape_layout_rule.drop? ? "—" : ad_shape_layout_rule.align %></div>
<div class='hg-col col-sm-1'><%= ad_shape_layout_rule.position %></div>

<div class="scaffold-line-buttons col-md-2">
    <%= form_with url: admin_ad_shape_ad_shape_layout_rule_path(ad_shape, ad_shape_layout_rule), html: {data: {'turbo-confirm': "Are you sure you want to delete #{ ad_shape_layout_rule.to_label }?" }, style: "display: inline-block;"}, method: :delete do |f| %>
      <%= f.submit "Delete".html_safe,  class: "delete-ad_shape_layout_rule-button btn btn-primary btn-sm" %>
    <% end %>

  <%= link_to "Edit ".html_safe, edit_admin_ad_shape_ad_shape_layout_rule_path(ad_shape, ad_shape_layout_rule) + (params[:page] ? "?page=#{params[:page]}" : ""), disable_with: "Loading...", class: "edit-ad_shape_layout_rule-button btn btn-primary btn-sm" %>
</div>
