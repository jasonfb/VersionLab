<% if @ad_shape_layout_rule.errors.none? %>
  <%= turbo_stream.replace "admin__ad_shape_layout_rules-list" + "__ad_shape-#{@ad_shape.id}" do %>
  <%= render partial: "list", locals: {ad_shape_layout_rules: @ad_shape_layout_rules,
   ad_shape: @ad_shape,
  nested_for: "ad_shape-#{@ad_shape.id}"
} %>

<% end %>
  <% end %>
<!-- parental updated -->
<%= turbo_stream.replace "__admin#{dom_id(@ad_shape)}" do %>
    <%= render partial: "admin/ad_shapes/line", locals: {ad_shape: @ad_shape} %>
  <% end %>
<!-- errors -->
  <%= turbo_stream.replace "admin__ad_shape_layout_rule-new" do %>
  <% if @ad_shape_layout_rule.errors.none? %>
  <%= render partial: "new_button", locals: {
ad_shape: @ad_shape

} %>
  <% else %>
  <%= render partial: "new_form", locals: {ad_shape_layout_rule: @ad_shape_layout_rule, ad_shape: @ad_shape } %>
  <% end %>
  <% end %>
  <%= turbo_stream.replace "flash_notices" do %>
  <%= render partial: "layouts/flash_notices", locals: {resource: @ad_shape_layout_rule} %>
<% end %>
